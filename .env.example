# ── arXiv Settings ──────────────────────────────────────────────
ARXIV_TOPICS="cs.AI,cs.LG"
ARXIV_MAX_RESULTS="50"

# ── LLM Settings (via litellm — supports any provider) ────────
# Model uses litellm format: "provider/model-name"
# Examples: openai/gpt-4o-mini, anthropic/claude-sonnet-4-20250514,
#           ollama/llama3, azure/gpt-4o, cohere/command-r-plus
LLM_API_KEY="sk-..."
LLM_MODEL="openai/gpt-4o-mini"
LLM_MAX_TOKENS="4096"
# Optional: override the API base URL (leave unset for provider defaults)
# LLM_API_BASE="https://custom-endpoint.example.com/v1"

# ── ChromaDB Settings ──────────────────────────────────────────
CHROMA_PERSIST_DIR="./data/chromadb"
CHROMA_COLLECTION="research_digest"

# ── Email / SMTP Settings ─────────────────────────────────────
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="you@gmail.com"
SMTP_PASSWORD="app-password-here"
EMAIL_FROM="you@gmail.com"
EMAIL_TO="recipient@example.com"

# ── Pipeline Modes ─────────────────────────────────────────────
DRY_RUN="true"

# ── Post-processing (practical implications & critiques) ──────
POSTPROCESSING_IMPLICATIONS="true"
POSTPROCESSING_CRITIQUES="true"

# ── PDF Download ─────────────────────────────────────────────
PDF_DOWNLOAD_MAX_RETRIES="3"

# ── Optional: HuggingFace Daily Papers ────────────────────────
HUGGINGFACE_ENABLED="false"
# Optional: HuggingFace API token (for higher rate limits)
# HUGGINGFACE_TOKEN="hf_..."
HUGGINGFACE_MAX_RESULTS="20"

# ── Optional: OpenAlex ────────────────────────────────────────
OPENALEX_ENABLED="false"
# Optional: OpenAlex API key (for higher rate limits)
# OPENALEX_API_KEY="..."
# Optional: email for OpenAlex polite pool (recommended)
# OPENALEX_EMAIL="you@example.com"
OPENALEX_MAX_RESULTS="20"
OPENALEX_QUERY="machine learning"
# Optional: filter by academic fields (JSON array)
# Valid fields: Computer Science, Mathematics, Physics and Astronomy,
#   Chemistry, Engineering, Medicine, Biology, Economics, etc.
# OPENALEX_FIELDS=["Computer Science","Mathematics"]

# Optional: Interest-based ranking (filters OpenAlex papers by relevance)
# Natural language description of your research interests
# OPENALEX_INTEREST_PROFILE="I study how large language models can be applied to scientific discovery"
# Comma-separated keywords for boosting (JSON array)
# OPENALEX_INTEREST_KEYWORDS=["LLM","drug discovery","protein folding"]
# How many papers to fetch before ranking (ranked down to OPENALEX_MAX_RESULTS)
OPENALEX_FETCH_POOL="100"

# ── Optional: GitHub Trending ──────────────────────────────────
GITHUB_ENABLED="false"
GITHUB_LANGUAGES="python,rust"
GITHUB_TOP_N="5"
